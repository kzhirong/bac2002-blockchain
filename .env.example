# Deployer wallet private key (no 0x prefix)
DEPLOYER_PRIVATE_KEY=

# Alchemy RPC URL for Polygon Amoy
ALCHEMY_AMOY_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_API_KEY

# Polygonscan API key for contract verification
POLYGONSCAN_API_KEY=

# Separate private key used by Veramo to sign JWT Verifiable Credentials.
# Must be DIFFERENT from DEPLOYER_PRIVATE_KEY (two-key design).
# Generate one with: node -e "const {ethers}=require('ethers'); console.log(ethers.Wallet.createRandom().privateKey)"
ISSUER_DID_PRIVATE_KEY=

# ── Supabase (Issuer Portal) ────────────────────────────────────────────────
# From your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-side only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=
